{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
    }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "hosting",
    "predeploy": [
      "npm --prefix \"../contracts\" run build",
      "rm -rf hosting",
      "cp -r ../contracts/out hosting"
    ],
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/admin/contracts/**/edit",
        "destination": "/admin/contracts/_/edit/index.html"
      },
      {
        "source": "/admin/contracts/**/renew",
        "destination": "/admin/contracts/_/renew/index.html"
      },
      {
        "source": "/admin/contracts/**",
        "destination": "/admin/contracts/_/index.html"
      },
      {
        "source": "/sign/**",
        "destination": "/sign/_/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ]
  },
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "storage": { "port": 9199 },
    "ui": { "enabled": true }
  }
}
